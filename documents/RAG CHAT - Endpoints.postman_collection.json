		{
			"name": "Session_Delete",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Session_Delete",
							"pm.test(\"Status code is 200 or 204\", function () {",
							"    pm.expect([200, 204]).to.include(pm.response.code);",
							"});",
							"pm.test(\"Response time is less than 1000ms\", function () {",
							"    pm.expect(pm.response.responseTime).to.be.below(1000);",
							"});",
							"pm.test(\"Response has Content-Type header if body exists\", function () {",
							"    if (pm.response.text()) {",
							"        pm.response.to.have.header(\"Content-Type\");",
							"    }",
							"});",
							"// Optionally check for success message in JSON",
							"if (pm.response.headers.get(\"Content-Type\") && pm.response.headers.get(\"Content-Type\").includes(\"application/json\")) {",
							"    var jsonData = pm.response.json();",
							"    pm.test(\"Response has 'message' property if present\", function () {",
							"        if (jsonData && jsonData.message !== undefined) {",
							"            pm.expect(jsonData).to.have.property(\"message\");",
							"        }",
							"    });",
							"}"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
